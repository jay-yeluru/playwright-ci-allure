{
  "name": "playwright-ci-allure",
  "version": "1.0.0",
  "description": "Playwright E2E tests with POM, BDD-style specs, and Allure reporting",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ci": "playwright test --reporter=line,allure-playwright",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "npm run allure:generate && npm run allure:open",
    "cleanup:reports": "ts-node scripts/cleanup-reports.ts",
    "cleanup:dry-run": "ts-node scripts/cleanup-reports.ts --dry-run"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.3.5",
    "allure-commandline": "^2.37.0",
    "allure-js-commons": "^3.0.0",
    "allure-playwright": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
